NODE_ENV=production
PORT=4000
TRUST_PROXY_HOPS=1

MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/dj-gig-platform?retryWrites=true&w=majority

JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=dj@example.com
ADMIN_PASSWORD=REPLACE_WITH_SECURE_BOOTSTRAP_PASSWORD

STRIPE_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET
MIN_TIP_AMOUNT=50
MAX_TIP_AMOUNT=50000
TIP_CURRENCY=cad

CLOUDINARY_CLOUD_NAME=REPLACE_WITH_YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_YOUR_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_YOUR_API_SECRET

CLIENT_ORIGIN=https://your-client.vercel.app
